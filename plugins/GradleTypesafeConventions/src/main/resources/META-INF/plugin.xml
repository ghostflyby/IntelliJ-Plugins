<idea-plugin>
    <id>dev.ghostflyby.gradle-typesafe-conventions</id>
    <name>Gradle Typesafe Conventions</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>com.intellij.gradle</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>org.jetbrains.plugins.gradle</depends>
    <depends>org.toml.lang</depends>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.plugins.gradle">
        <projectResolve
                implementation="dev.ghostflyby.typesafeconventions.gradle.TypesafeConventionsProjectResolverExtension"/>
        <!--suppress PluginXmlValidity Experimental API usage -->
        <syncContributor
                implementation="dev.ghostflyby.typesafeconventions.gradle.TypesafeConventionsGradleSyncContributor"/>
    </extensions>
    <extensions defaultExtensionNs="com.intellij">
        <!--suppress PluginXmlValidity Experimental API usage -->
        <externalWorkspaceDataService
                implementation="dev.ghostflyby.typesafeconventions.gradle.TypesafeConventionsGradleModuleDataService"
                order="last"/>
    </extensions>
</idea-plugin>
