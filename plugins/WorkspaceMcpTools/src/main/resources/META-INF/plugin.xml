<idea-plugin>
    <id>dev.ghostflyby.mcp.workspace</id>
    <name>Workspace MCP</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>

    <depends>com.intellij.mcpServer</depends>

    <extensionPoints>
        <extensionPoint name="workspaceFeature"
                        interface="dev.ghostflyby.mcp.sdk.WorkspaceMcpFeature"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="dev.ghostflyby.mcp.workspace">
        <workspaceFeature implementation="dev.ghostflyby.mcp.core.CoreResourceFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.vfs.resources.VfsResourceFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.document.resources.DocumentResourceFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.descriptor.ScopeDescriptorFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.quality.QualityFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.search.ScopeFileSearchFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.symbol.ScopeSymbolSearchFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.navigation.NavigationFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.text.ScopeTextSearchFeature"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="dev.ghostflyby.mcp.sdk.WorkspaceMcpSdkServerStartupActivity"/>
    </extensions>

</idea-plugin>
