<idea-plugin>
    <id>dev.ghostflyby.mcp.workspace</id>
    <name>Workspace MCP</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>com.intellij.mcpServer</depends>

    <extensionPoints>
        <extensionPoint name="workspaceFeature"
                        interface="dev.ghostflyby.mcp.sdk.WorkspaceMcpFeature"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="dev.ghostflyby.mcp.workspace">
        <workspaceFeature implementation="dev.ghostflyby.mcp.core.CoreResourceFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.vfs.resources.VfsResourceFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.document.resources.DocumentResourceFeature"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="dev.ghostflyby.mcp.sdk.WorkspaceMcpSdkServerStartupActivity"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.mcpServer">
        <mcpToolset implementation="dev.ghostflyby.mcp.vfs.VfsMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.document.DocumentMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.navigation.SymbolNavigationMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.quality.CodeQualityMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.scope.descriptor.ScopeDescriptorMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.scope.search.ScopeFileSearchMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.scope.symbol.ScopeSymbolSearchMcpTools"/>
        <mcpToolset implementation="dev.ghostflyby.mcp.scope.text.ScopeTextSearchMcpTools"/>
    </extensions>
</idea-plugin>
