<idea-plugin>
    <id>dev.ghostflyby.mcp.workspace</id>
    <name>Workspace MCP</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>

    <extensionPoints>
        <extensionPoint name="workspaceFeature"
                        interface="dev.ghostflyby.mcp.server.WorkspaceMcpFeature"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="dev.ghostflyby.mcp.workspace">
        <workspaceFeature implementation="dev.ghostflyby.mcp.filecontent.FileContentFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.descriptor.ScopeDescriptorFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.quality.QualityFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.search.ScopeFileSearchFeature"/>
        <workspaceFeature implementation="dev.ghostflyby.mcp.scope.symbol.ScopeSymbolSearchFeature"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="dev.ghostflyby.mcp.WorkspaceMcpStartupActivity"/>
        <vfs.asyncListener implementation="dev.ghostflyby.mcp.filecontent.FileContentVfsListener"/>
    </extensions>

    <applicationListeners>
        <listener class="dev.ghostflyby.mcp.sdk.WorkspaceMcpProjectLifecycleListener"
                  topic="com.intellij.openapi.project.ProjectManager$TOPIC"/>
    </applicationListeners>

    <projectListeners>
        <listener class="dev.ghostflyby.mcp.sdk.WorkspaceMcpModuleRootListener"
                  topic="com.intellij.openapi.roots.ModuleRootListener$TOPIC"/>
    </projectListeners>

</idea-plugin>
