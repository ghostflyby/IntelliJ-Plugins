<idea-plugin>
    <id>dev.ghostflyby.mcp.workspace</id>
    <name>Workspace Agent Bridge</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.vcs</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Workspace Agent Bridge"
                           displayType="BALLOON"
                           bundle="messages.Bundle"
                           key="sdk.notification.group.name"/>
        <postStartupActivity implementation="dev.ghostflyby.mcp.WorkspaceMcpStartupActivity"/>
        <postStartupActivity implementation="dev.ghostflyby.mcp.sdk.SkillNotificationActivity"/>
    </extensions>

</idea-plugin>
