<idea-plugin>
    <id>dev.ghostflyby.agent-skills-editing</id>
    <name>Agent Skills Editing</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.intellij.plugins.markdown</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="JavaScript">
        <JsonSchema.ProviderFactory
                implementation="dev.ghostflyby.skills.SkillMdJsonSchemaProviderFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <localInspection
                language="yaml"
                shortName="SkillFrontmatterStructureInspection"
                displayName="Skill Frontmatter Structure"
                groupName="Agent Skills"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillFrontmatterStructureInspection"/>

        <localInspection
                language="yaml"
                shortName="SkillNameInspection"
                displayName="Skill Name"
                groupName="Agent Skills"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillNameInspection"/>

        <localInspection
                language="yaml"
                shortName="SkillDescriptionInspection"
                displayName="Skill Description"
                groupName="Agent Skills"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillDescriptionInspection"/>

        <localInspection
                language="yaml"
                shortName="SkillOptionalFieldsInspection"
                displayName="Skill Optional Fields"
                groupName="Agent Skills"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillOptionalFieldsInspection"/>
    </extensions>

</idea-plugin>
