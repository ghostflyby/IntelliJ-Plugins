<idea-plugin>
    <id>dev.ghostflyby.agent-skills-editing</id>
    <name>Agent Skills Editing</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.intellij.plugins.markdown</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="JavaScript">
        <JsonSchema.ProviderFactory order="first"
                                    implementation="dev.ghostflyby.skills.SkillMdJsonSchemaProviderFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <psi.declarationProvider
                implementation="dev.ghostflyby.skills.SkillNameDeclarationProvider"/>
        <searcher
                forClass="com.intellij.refactoring.rename.api.RenameUsageSearchParameters"
                implementationClass="dev.ghostflyby.skills.SkillNameRenameUsageSearcher"/>

        <referencesSearch
                implementation="dev.ghostflyby.skills.SkillDirRenameSearchExecutor"/>
        <gotoDeclarationHandler
                implementation="dev.ghostflyby.skills.SkillNameGotoDeclarationHandler"/>

        <localInspection
                language="Markdown"
                shortName="SkillMdFrontmatterInspection"
                key="inspection.skills.frontmatter.display.name"
                bundle="messages.SkillMdBundle"
                groupKey="inspection.skills.group.name"
                groupBundle="messages.SkillMdBundle"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillMdFrontmatterInspection"/>

        <localInspection
                language="yaml"
                shortName="SkillNameInspection"
                key="inspection.skills.name.display.name"
                bundle="messages.SkillMdBundle"
                groupKey="inspection.skills.group.name"
                groupBundle="messages.SkillMdBundle"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="dev.ghostflyby.skills.SkillNameInspection"/>
    </extensions>

</idea-plugin>
