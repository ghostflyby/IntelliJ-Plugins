<idea-plugin>

    <id>dev.ghostflyby.vitepress</id>
    <name>VitePress</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.intellij.plugins.markdown</depends>
    <depends>org.jetbrains.plugins.vue</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="VitePress"
                           displayType="BALLOON"
                           bundle="messages.Bundle"
                           key="notification.group"/>
        <applicationConfigurable bundle="messages.Bundle"
                                 id="dev.ghostflyby.vitepress.application"
                                 instance="dev.ghostflyby.vitepress.VitePressApplicationConfigurable"
                                 key="configuration.title"
                                 parentId="editor"/>
        <lang.parserDefinition
                language="VitePress"
                implementationClass="dev.ghostflyby.vitepress.VitePressParserDefinition"/>
        <lang.fileViewProviderFactory
                language="VitePress"
                id="VitePressFileViewerProviderFactory"
                implementationClass="dev.ghostflyby.vitepress.VitePressFileViewProvider$Factory"/>
        <fileType name="VitePress" language="VitePress" fieldName="INSTANCE"
                  implementationClass="dev.ghostflyby.vitepress.VitePressFiletype"/>
        <multiLangCommenter implementation="dev.ghostflyby.vitepress.VitePressCommentProvider"/>
        <editorHighlighterProvider filetype="VitePress"
                                   implementationClass="dev.ghostflyby.vitepress.VitePressHighlighterFactory"/>
        <spellchecker.bundledDictionaryProvider implementation="dev.ghostflyby.vitepress.spellcheck.Dict"/>
        <fileTypeOverrider implementation="dev.ghostflyby.vitepress.VitePressFileTypeOverrider"/>
        <webBrowserUrlProvider implementation="dev.ghostflyby.vitepress.preview.VitePressUrlProvider"/>
        <postStartupActivity implementation="dev.ghostflyby.vitepress.VitePressRootTrackerActivity"/>
        <vfs.asyncListenerBackgroundable implementation="dev.ghostflyby.vitepress.VitePressRootTrackerFileListener"/>
        <annotator language="Markdown"
                   order="last"
                   implementationClass="dev.ghostflyby.vitepress.VitePressHeadingInterpolationAnnotator"/>
        <daemon.highlightInfoFilter implementation="dev.ghostflyby.vitepress.VitePressHeadingHighlightInfoFilter"/>
    </extensions>
    <projectListeners>
        <listener class="dev.ghostflyby.vitepress.preview.PreviewNpmListener"
                  topic="com.intellij.execution.ExecutionListener"/>
    </projectListeners>

</idea-plugin>
