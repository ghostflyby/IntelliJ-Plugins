<idea-plugin>
    <extensions defaultExtensionNs="org.jetbrains.plugins.gradle">
        <projectResolve implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleProjectResolverExtension"/>
    </extensions>
    <extensions defaultExtensionNs="com.intellij">
        <externalProjectDataService implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleStateDataService"/>
        <projectConfigurable bundle="messages.Bundle" id="dev.ghostflyby.spotless.workspace"
                             instance="dev.ghostflyby.spotless.gradle.SpotlessGradleConfigurable"
                             key="spotless.configuration.title.workspace"
                             parentId="build"/>
    </extensions>
    <extensions defaultExtensionNs="dev.ghostflyby.spotless">
        <spotlessDaemonProvider implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleExtension"/>
    </extensions>
    <actions resource-bundle="messages.Bundle">
        <group id="dev.ghostflyby.spotless.actions" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="dev.ghostflyby.spotless.stopDaemons"
                    class="dev.ghostflyby.spotless.gradle.StopSpotlessDaemonsAction"/>
        </group>
    </actions>
    <resource-bundle>messages.Bundle</resource-bundle>
</idea-plugin>
