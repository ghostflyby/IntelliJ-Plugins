<idea-plugin>
    <extensions defaultExtensionNs="org.jetbrains.plugins.gradle">
        <taskManager implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleTaskManagerExtension"/>
        <projectResolve implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleProjectResolverExtension"/>
    </extensions>
    <extensions defaultExtensionNs="com.intellij">
        <externalProjectDataService implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleStateDataService"/>
    </extensions>
    <extensions defaultExtensionNs="dev.ghostflyby.spotless">
        <spotlessDaemonProvider implementation="dev.ghostflyby.spotless.gradle.SpotlessGradleExtension"/>
    </extensions>
    <actions>
        <group id="dev.ghostflyby.spotless.actions" text="Spotless" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="dev.ghostflyby.spotless.stopDaemons"
                    class="dev.ghostflyby.spotless.gradle.StopSpotlessDaemonsAction"
                    text="Stop Spotless Daemons"
                    description="Stop all running Spotless daemon processes for this project."/>
            <action id="dev.ghostflyby.spotless.restartDaemons"
                    class="dev.ghostflyby.spotless.gradle.RestartSpotlessDaemonsAction"
                    text="Restart Spotless Daemons"
                    description="Stop running Spotless daemon processes so they restart on the next format request."/>
        </group>
    </actions>
</idea-plugin>
