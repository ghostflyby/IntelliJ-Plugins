<idea-plugin>
    <id>dev.ghostflyby.spotless</id>
    <name>Spotless</name>
    <vendor>ghostflyby</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="gradle.xml">com.intellij.gradle</depends>
    <depends optional="true" config-file="java.xml">com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <formattingService implementation="dev.ghostflyby.spotless.SpotlessFormatingService"/>
        <statusBarWidgetFactory id="dev.ghostflyby.spotless.statusBar"
                                implementation="dev.ghostflyby.spotless.SpotlessStatusBarWidgetFactory"
                                order="before ReadOnlyAttribute"/>
        <postStartupActivity implementation="dev.ghostflyby.spotless.SpotlessStatusBarWidgetActivity"/>
    </extensions>

    <extensionPoints>
        <extensionPoint name="spotlessDaemonProvider" interface="dev.ghostflyby.spotless.api.SpotlessDaemonProvider"
                        dynamic="true"/>
        <extensionPoint name="spotlessDaemonProviderPresentation"
                        interface="dev.ghostflyby.spotless.api.frontend.SpotlessDaemonProviderPresentation"
                        dynamic="true"/>
        <extensionPoint name="spotlessFormattingPreprocessor"
                        interface="dev.ghostflyby.spotless.api.SpotlessFormattingPreprocessor" dynamic="true"/>
    </extensionPoints>
</idea-plugin>
